<div class="flex" style="justify-content:space-between;align-items:center;margin-bottom:20px">
  <h1 class="bb-page-title" style="margin-bottom:0">👥 Members</h1>
  <a href="/customers/new" class="btn btn-primary">+ New Member</a>
</div>

<form method="GET" action="/customers">
  <div class="bb-search">
    <input type="text" name="search" placeholder="Search name or email..." value="<%= query.search || '' %>">
    <select name="active">
      <option value="">All Members</option>
      <option value="1" <%= query.active === '1' ? 'selected' : '' %>>Active</option>
      <option value="0" <%= query.active === '0' ? 'selected' : '' %>>Inactive</option>
    </select>
    <button type="submit" class="btn btn-blue">Search</button>
    <a href="/customers" class="btn btn-blue">Clear</a>
  </div>
</form>

<div class="bb-table-wrap">
  <table>
    <thead>
      <tr>
        <th>Name</th>
        <th>Email</th>
        <th>City</th>
        <th>Country</th>
        <th>Status</th>
        <th>Rentals</th>
        <th>Member Since</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% customers.forEach(c => { %>
      <tr class="<%= c.activebool ? '' : 'inactive' %>">
        <td><a href="/customers/<%= c.customer_id %>" class="text-yellow" style="text-decoration:none"><%= c.last_name %>, <%= c.first_name %></a></td>
        <td><span class="text-muted"><%= c.email || '—' %></span></td>
        <td><%= c.city || '—' %></td>
        <td><%= c.country || '—' %></td>
        <td><span class="badge <%= c.activebool ? 'badge-active' : 'badge-inactive' %>"><%= c.activebool ? 'Active' : 'Inactive' %></span></td>
        <td><%= c.total_rentals %></td>
        <td><%= new Date(c.create_date).toLocaleDateString() %></td>
        <td>
          <div class="btn-group">
            <a href="/customers/<%= c.customer_id %>/edit" class="btn btn-sm btn-blue">Edit</a>
            <form method="POST" action="/customers/<%= c.customer_id %>?_method=DELETE" style="display:inline" onsubmit="return confirm('Delete this customer?')">
              <button type="submit" class="btn btn-sm btn-danger">Del</button>
            </form>
          </div>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<% if (totalPages > 1) { %>
<div class="bb-pagination">
  <% for (let i = 1; i <= totalPages; i++) { %>
    <% const q = new URLSearchParams({...query, page: i}).toString(); %>
    <a href="/customers?<%= q %>" class="<%= i === page ? 'current' : '' %>"><%= i %></a>
  <% } %>
</div>
<% } %>
