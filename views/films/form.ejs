<div class="flex" style="justify-content:space-between;align-items:center;margin-bottom:20px">
  <h1 class="bb-page-title" style="margin-bottom:0"><%= film.film_id ? '✏ Edit Film' : '+ New Film' %></h1>
  <a href="/films<%= film.film_id ? '/' + film.film_id : '' %>" class="btn btn-blue">Cancel</a>
</div>

<form method="POST" action="<%= action %>">
  <div class="bb-card">
    <h2>Basic Info</h2>
    <div class="bb-form">
      <div class="form-group">
        <label>Title *</label>
        <input type="text" name="title" value="<%= film.title || '' %>" required>
      </div>
      <div class="form-group">
        <label>Description</label>
        <textarea name="description"><%= film.description || '' %></textarea>
      </div>
      <div class="bb-form-row">
        <div class="form-group">
          <label>Release Year</label>
          <input type="number" name="release_year" value="<%= film.release_year || '' %>" min="1900" max="2099">
        </div>
        <div class="form-group">
          <label>Language *</label>
          <select name="language_id" required>
            <% languages.forEach(l => { %>
              <option value="<%= l.language_id %>" <%= film.language_id == l.language_id ? 'selected' : '' %>><%= l.name.trim() %></option>
            <% }) %>
          </select>
        </div>
        <div class="form-group">
          <label>Rating</label>
          <select name="rating">
            <% ['G','PG','PG-13','R','NC-17'].forEach(r => { %>
              <option value="<%= r %>" <%= film.rating === r ? 'selected' : '' %>><%= r %></option>
            <% }) %>
          </select>
        </div>
      </div>
      <div class="bb-form-row">
        <div class="form-group">
          <label>Length (min)</label>
          <input type="number" name="length" value="<%= film.length || '' %>" min="1">
        </div>
        <div class="form-group">
          <label>Rental Rate ($)</label>
          <input type="number" name="rental_rate" value="<%= film.rental_rate || '4.99' %>" step="0.01" min="0">
        </div>
        <div class="form-group">
          <label>Rental Duration (days)</label>
          <input type="number" name="rental_duration" value="<%= film.rental_duration || '3' %>" min="1">
        </div>
        <div class="form-group">
          <label>Replacement Cost ($)</label>
          <input type="number" name="replacement_cost" value="<%= film.replacement_cost || '19.99' %>" step="0.01" min="0">
        </div>
      </div>
    </div>
  </div>

  <div class="bb-card">
    <h2>Categories</h2>
    <div style="display:flex;flex-wrap:wrap;gap:10px">
      <% categories.forEach(c => { %>
        <label class="form-check">
          <input type="checkbox" name="category_ids" value="<%= c.category_id %>"
            <%= selectedCategories.includes(c.category_id) ? 'checked' : '' %>>
          <%= c.name %>
        </label>
      <% }) %>
    </div>
  </div>

  <div class="bb-card">
    <h2>Cast / Actors</h2>
    <input type="text" id="actor-search" placeholder="Filter actors..." style="margin-bottom:12px;max-width:300px">
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:6px;max-height:280px;overflow-y:auto;padding:4px" id="actor-list">
      <% actors.forEach(a => { %>
        <label class="form-check actor-row">
          <input type="checkbox" name="actor_ids" value="<%= a.actor_id %>"
            <%= selectedActors.includes(a.actor_id) ? 'checked' : '' %>>
          <%= a.name %>
        </label>
      <% }) %>
    </div>
  </div>

  <div class="btn-group">
    <button type="submit" class="btn btn-primary">💾 Save Film</button>
    <a href="/films<%= film.film_id ? '/' + film.film_id : '' %>" class="btn btn-blue">Cancel</a>
  </div>
</form>

<script>
document.getElementById('actor-search').addEventListener('input', function() {
  const q = this.value.toLowerCase();
  document.querySelectorAll('.actor-row').forEach(row => {
    row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
  });
});
</script>
