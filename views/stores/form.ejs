<div class="flex" style="justify-content:space-between;align-items:center;margin-bottom:20px">
  <h1 class="bb-page-title" style="margin-bottom:0">✏ Edit Store</h1>
  <a href="/stores" class="btn btn-blue">Cancel</a>
</div>

<form method="POST" action="<%= action %>">
  <div class="bb-card">
    <h2>Store Info</h2>
    <div class="bb-form">
      <div class="form-group">
        <label>Manager *</label>
        <select name="manager_staff_id" required>
          <% staff.forEach(s => { %>
            <option value="<%= s.staff_id %>" <%= store.manager_staff_id == s.staff_id ? 'selected' : '' %>><%= s.name %></option>
          <% }) %>
        </select>
      </div>
    </div>
  </div>

  <div class="bb-card">
    <h2>Address</h2>
    <div class="bb-form">
      <div class="form-group">
        <label>Street Address *</label>
        <input type="text" name="address" value="<%= store.address || '' %>" required>
      </div>
      <div class="form-group">
        <label>Address Line 2</label>
        <input type="text" name="address2" value="<%= store.address2 || '' %>">
      </div>
      <div class="bb-form-row">
        <div class="form-group">
          <label>District *</label>
          <input type="text" name="district" value="<%= store.district || '' %>" required>
        </div>
        <div class="form-group">
          <label>Postal Code</label>
          <input type="text" name="postal_code" value="<%= store.postal_code || '' %>">
        </div>
        <div class="form-group">
          <label>Phone</label>
          <input type="text" name="phone" value="<%= store.phone || '' %>">
        </div>
      </div>
      <div class="form-group">
        <label>City *</label>
        <input type="text" id="city-search" placeholder="Type to filter cities..." style="margin-bottom:6px">
        <select name="city_id" id="city-select" required size="6" style="height:auto">
          <% cities.forEach(c => { %>
            <option value="<%= c.city_id %>" <%= store.city_id == c.city_id ? 'selected' : '' %>><%= c.city %>, <%= c.country %></option>
          <% }) %>
        </select>
      </div>
    </div>
  </div>

  <div class="btn-group">
    <button type="submit" class="btn btn-primary">💾 Save Store</button>
    <a href="/stores" class="btn btn-blue">Cancel</a>
  </div>
</form>

<script>
document.getElementById('city-search').addEventListener('input', function() {
  const q = this.value.toLowerCase();
  document.querySelectorAll('#city-select option').forEach(opt => {
    opt.style.display = opt.textContent.toLowerCase().includes(q) ? '' : 'none';
  });
});
</script>
