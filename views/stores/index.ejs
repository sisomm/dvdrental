<div class="flex" style="justify-content:space-between;align-items:center;margin-bottom:20px">
  <h1 class="bb-page-title" style="margin-bottom:0">🏪 Stores</h1>
  <a href="/stores/new" class="btn btn-primary">+ New Store</a>
</div>

<div class="bb-table-wrap">
  <table>
    <thead>
      <tr>
        <th>Store</th>
        <th>Manager</th>
        <th>Address</th>
        <th>City</th>
        <th>Members</th>
        <th>Inventory</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% stores.forEach(s => { %>
      <tr>
        <td class="text-yellow"><%= s.city %></td>
        <td><%= s.manager %></td>
        <td><%= s.address %></td>
        <td><%= s.city %>, <%= s.country %></td>
        <td><%= s.customers %></td>
        <td><%= s.inventory %> titles</td>
        <td>
          <a href="/stores/<%= s.store_id %>/edit" class="btn btn-sm btn-blue">Edit</a>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>
